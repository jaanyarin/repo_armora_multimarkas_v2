# ARMORA Multimarkas v2 - variables de entorno de ejemplo
#
# Copiar este archivo como .env.local o equivalente por entorno.
# No colocar secretos reales en este archivo.
# No subir archivos .env reales al repositorio.

# Entorno
APP_ENV=local
APP_NAME=armora-multimarkas-v2
APP_TIMEZONE=America/Lima

# Backend Quarkus
API_HOST=0.0.0.0
API_PORT=8080
API_BASE_PATH=/api/v1
API_PUBLIC_URL=http://localhost:8080/api/v1

# Base de datos PostgreSQL
POSTGRES_DB=armora
POSTGRES_USER=armora_user
POSTGRES_PASSWORD=<local-dev-password>
POSTGRES_PORT=5432
DATABASE_URL=jdbc:postgresql://localhost:5432/armora
DATABASE_USERNAME=armora_user
DATABASE_PASSWORD=<local-dev-password>
SEED_ADMIN_PASSWORD=<local-dev-password>

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Seguridad / JWT / OIDC
JWT_ISSUER=armora-local
JWT_PRIVATE_KEY_PATH=file:./backend/api-quarkus/secrets/local/privatekey.pem
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET_PATH=

# Admin web Next.js
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_APP_ENV=local

# Flutter cliente
CLIENTE_API_BASE_URL=http://10.0.2.2:8080/api/v1
CLIENTE_APP_ENV=local

# Flutter proveedor
PROVEEDOR_API_BASE_URL=http://10.0.2.2:8080/api/v1
PROVEEDOR_APP_ENV=local

# Integraciones futuras - no completar con secretos reales aqui
PAYMENT_PROVIDER=
PAYMENT_PUBLIC_KEY=
PAYMENT_SECRET_KEY_PATH=
SUNAT_ENV=disabled
SUNAT_CLIENT_ID=
SUNAT_CLIENT_SECRET_PATH=

# Observabilidad local
LOG_LEVEL=INFO
ENABLE_REQUEST_LOG=true

# Tests - PostgreSQL contenedor (ver backend/api-quarkus/scripts/test-db.ps1)
TEST_DATABASE_URL=jdbc:postgresql://localhost:5433/armora_test
TEST_DATABASE_USERNAME=armora_test
TEST_DATABASE_PASSWORD=armora_test_pass
